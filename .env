# PostgreSQL
POSTGRES_DB=MED_USER_DB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=MED_USER_PASSWORD

# MedUserService
DB_HOST=postgres
DB_PORT=5432
DB_NAME=MED_USER_DB
DB_USERNAME=postgres
DB_PASSWORD=MED_USER_PASSWORD
USER_SERVICE_NAME=med-user-service

# MedDiscovery
EUREKA_SERVER_URL=http://med-discovery-service:8761/eureka

# MedCoreService
MONGO_ROOT_USERNAME=MED_CORE_USER
MONGO_ROOT_PASSWORD=MED_CORE_PASSWORD
MONGO_DATABASE=MED_CORE_DB
CORE_SERVICE_NAME=med-core-service

# Shared Configs
CONFIG_SERVER_URL=http://med-config-service:8086/api
ACTIVE_PROFILE=local

# MedChatBootService
CHATBOOT_SERVICE_NAME=med-chatboot-service

# MedNotificationService
NOTIFICATION_SERVICE_NAME=med-notification-service
